<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<AnchorPane fx:id="pane" styleClass="clientes-pane" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gerenciador.controller.ServicosController">

    <children>
        <HBox spacing="40.0" style="-fx-padding: 30px;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <children>

                <VBox alignment="TOP_CENTER" minWidth="485.0" prefWidth="485.0" spacing="10.0" HBox.hgrow="NEVER">
                    <padding>
                        <Insets left="10.0" right="10.0" />
                    </padding>

                    <children>
                        <Label fx:id="h1Formulario" alignment="CENTER" maxWidth="Infinity" styleClass="h1-formulario" text="Cadastrar Serviços">
                            <padding>
                                <Insets bottom="10" left="10" right="10" top="10" />
                            </padding>
                        </Label>

                        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox spacing="20.0">
                                    <children>

                                        <VBox fx:id="vboxServico" maxWidth="1.7976931348623157E308" styleClass="box-formulario-servico" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="labelServico" alignment="CENTER" maxWidth="Infinity" styleClass="tipoPessoa-box" text="Novo Serviço" />
                                                <VBox spacing="15.0" VBox.vgrow="ALWAYS">
                                                    <padding>
                                                        <Insets bottom="20" left="30" right="30" top="20" />
                                                    </padding>
                                                    <children>
                                                        <VBox spacing="5.0">
                                                            <Label styleClass="labels-formulario" text="Nome do Serviço" />
                                                            <TextField fx:id="txtNomeServico" maxWidth="Infinity" promptText="Digite o nome do serviço" styleClass="textFields-formulario" />
                                                        </VBox>
                                                    </children>
                                                </VBox>
                                                <StackPane minHeight="40.0">
                                                    <children>
                                                        <Label fx:id="erroLabelServico" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill:#E74C3C; -fx-font-weight:bold; -fx-background-color:#FDECEA; -fx-padding:10; -fx-background-radius:5;" visible="false" />
                                                        <Label fx:id="sucessoLabelServico" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill:#1E7E34; -fx-font-weight:bold; -fx-background-color:#D4EDDA; -fx-padding:10; -fx-background-radius:5;" visible="false" />
                                                    </children>
                                                </StackPane>
                                                <HBox alignment="CENTER" spacing="20.0">
                                                    <padding>
                                                        <Insets bottom="20" top="10" />
                                                    </padding>
                                                    <children>
                                                        <HBox fx:id="boxCadastrarServico" managed="true" visible="true">
                                                            <Button onAction="#cadastrarServico" styleClass="cadastrar-btn" text="Cadastrar" />
                                                        </HBox>
                                                        <HBox fx:id="boxAtualizarServico" managed="false" spacing="20" visible="false">
                                                            <Button onAction="#ativarModoCadastro" styleClass="trocar-btn" text="Cancelar" />
                                                            <Button onAction="#cadastrarServico" styleClass="cadastrar-btn" text="Atualizar" />
                                                        </HBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <VBox fx:id="vboxProduto" styleClass="box-formulario-servico" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="labelProduto" alignment="CENTER" maxWidth="Infinity" styleClass="tipoPessoa-box" text="Novo Produto" />
                                                <VBox spacing="15.0" VBox.vgrow="ALWAYS">
                                                    <padding>
                                                        <Insets bottom="20" left="30" right="30" top="20" />
                                                    </padding>
                                                    <children>
                                                        <VBox spacing="5.0">
                                                            <Label styleClass="labels-formulario" text="Nome do Produto" />
                                                            <TextField fx:id="txtNomeProduto" maxWidth="Infinity" promptText="Digite o nome do produto" styleClass="textFields-formulario" />
                                                        </VBox>
                                                        <VBox spacing="5.0">
                                                            <Label styleClass="labels-formulario" text="Matérias-Primas" />
                                                            <MenuButton fx:id="menuMateriasPrimas" maxWidth="Infinity" styleClass="textFields-formulario" text="Selecione" />
                                                        </VBox>
                                                    </children>
                                                </VBox>
                                                <StackPane minHeight="40.0">
                                                    <children>
                                                        <Label fx:id="erroLabelProduto" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill:#E74C3C; -fx-font-weight:bold; -fx-background-color:#FDECEA; -fx-padding:10; -fx-background-radius:5;" visible="false" />
                                                        <Label fx:id="sucessoLabelProduto" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill:#1E7E34; -fx-font-weight:bold; -fx-background-color:#D4EDDA; -fx-padding:10; -fx-background-radius:5;" visible="false" />
                                                    </children>
                                                </StackPane>
                                                <HBox alignment="CENTER" spacing="20.0">
                                                    <padding>
                                                        <Insets bottom="20" top="10" />
                                                    </padding>
                                                    <children>
                                                        <HBox fx:id="boxCadastrarProduto" managed="true" visible="true">
                                                            <Button onAction="#cadastrarProduto" styleClass="cadastrar-btn" text="Cadastrar" />
                                                        </HBox>
                                                        <HBox fx:id="boxAtualizarProduto" managed="false" spacing="20" visible="false">
                                                            <Button onAction="#ativarModoCadastro" styleClass="trocar-btn" text="Cancelar" />
                                                            <Button onAction="#cadastrarProduto" styleClass="cadastrar-btn" text="Atualizar" />
                                                        </HBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

                <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" VBox.vgrow="NEVER">
                            <children>
                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" minHeight="50.0" spacing="10.0" styleClass="barra-pesquisa-container" HBox.hgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" minWidth="300.0" prefWidth="300.0" styleClass="search-box-container" HBox.hgrow="ALWAYS">
                                            <children>
                                                <SVGPath content="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" styleClass="search-icon" />
                                                <TextField fx:id="txtPesquisa" maxWidth="1.7976931348623157E308" prefHeight="24.0" promptText="Pesquisar..." styleClass="search-field-transparent" HBox.hgrow="ALWAYS" />
                                            </children>
                                            <padding>
                                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                                            </padding>
                                        </HBox>
                                        <VBox maxHeight="40.0" prefHeight="20.0" prefWidth="1.0" style="-fx-background-color: #E0E0E0;" />
                                        <Label fx:id="labelFiltro" style="-fx-font-weight: bold; -fx-text-fill: #666;" text="Filtrar:" />
                                        <ComboBox fx:id="filtroTabela" prefHeight="24.0" prefWidth="181.0" promptText="Todos" styleClass="combo-filtro" />
                                    </children>
                                    <padding>
                                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                                    </padding>
                                </HBox>
                            </children>
                        </HBox>

                        <VBox styleClass="box-tabela" VBox.vgrow="ALWAYS">
                            <children>
                                <TableView fx:id="tabelaServicos" styleClass="tabela-custom" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colId" minWidth="60" prefWidth="80" text="ID" reorderable="false" />
                                        <TableColumn fx:id="colTipo" minWidth="150" prefWidth="200" text="Categoria/Tipo" reorderable="false"/>
                                        <TableColumn fx:id="colNome" minWidth="200" prefWidth="350" text="Nome do Serviço" reorderable="false"/>
                                        <TableColumn fx:id="colTotalVendido" minWidth="150" prefWidth="180" text="Volume Vendido" reorderable="false"/>
                                        <TableColumn fx:id="colAcoes" minWidth="100" maxWidth="120" prefWidth="110" text="Ações" reorderable="false"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
            <Button fx:id="servicosBtn" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onNavigate" prefHeight="100.0" styleClass="sidebar-buttons" text="Serviços" userData="servicos.fxml">

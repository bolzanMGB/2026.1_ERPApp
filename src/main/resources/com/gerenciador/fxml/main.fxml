            <Button fx:id="comprasBtn" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onNavigate" prefHeight="100.0" styleClass="sidebar-buttons" text="Compras" userData="compras.fxml">
